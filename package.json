{
	"name": "@jobmatchme/bee-worker-sidecar",
	"version": "0.1.1",
	"description": "NATS to Unix socket bridge for Bee Dance speaking workers",
	"type": "module",
	"bin": {
		"bee-worker-sidecar": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"homepage": "https://github.com/jobmatchme/bee-worker-sidecar",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jobmatchme/bee-worker-sidecar.git"
	},
	"bugs": {
		"url": "https://github.com/jobmatchme/bee-worker-sidecar/issues"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"keywords": [
		"agents",
		"sidecar",
		"protocol",
		"nats",
		"socket"
	],
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf coverage dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write --error-on-warnings .",
		"format": "biome format --write .",
		"typecheck": "tsgo --noEmit -p tsconfig.json",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"check": "biome check --write --error-on-warnings . && tsgo --noEmit -p tsconfig.json && vitest run --coverage && npm run build",
		"prepare": "husky",
		"prepublishOnly": "npm run clean && npm run check"
	},
	"dependencies": {
		"@jobmatchme/bee-dance-core": "0.1.5",
		"nats": "^2.29.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"@types/node": "^24.3.0",
		"@vitest/coverage-v8": "^3.2.4",
		"husky": "^9.1.7",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"optionalDependencies": {
		"@typescript/native-preview-linux-arm64": "7.0.0-dev.20260120.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"license": "MIT"
}
